# Ghost Agent — Environment Variables
# Copy to .env and fill in real values

# ── API Keys ────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ── Network & Host ──────────────────────────────────────────
GHOST_MAC_HOST=192.168.1.6

# ── AI / Ollama ─────────────────────────────────────────────
OLLAMA_URL=http://192.168.1.6:11434
GHOST_MODEL=gemma4
GHOST_PROJECT=pickle-rick

# ── Nexus AI Gateway ────────────────────────────────────────
NEXUS_URL=https://nexus.subatomic.pro
NEXUS_KEY=your_nexus_api_key_here

# ── Home Assistant ──────────────────────────────────────────
GHOST_HA_URL=http://homeassistant.local:8123
GHOST_HA_TOKEN=your_home_assistant_long_lived_access_token_here

# ── Quiet Hours (24h format) ────────────────────────────────
GHOST_QUIET_START=22
GHOST_QUIET_END=7

# ── Weather (lat/lon for location-aware context) ────────────
GHOST_WEATHER_LAT=29.76
GHOST_WEATHER_LON=-95.37
