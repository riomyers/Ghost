#!/usr/bin/env python3
"""ghost-say — Speak text with Pickle Rick's voice via ElevenLabs."""

import sys
import os
sys.path.insert(0, os.path.expanduser("~/ghost/lib"))

import voice

def main():
    if len(sys.argv) < 2:
        print("Usage: ghost-say <text>", file=sys.stderr)
        print("  ghost-say 'I turned myself into a pickle!'", file=sys.stderr)
        print("  echo 'text' | ghost-say -", file=sys.stderr)
        sys.exit(1)

    if sys.argv[1] == "-":
        text = sys.stdin.read().strip()
    elif sys.argv[1] == "--file":
        if len(sys.argv) < 4:
            print("Usage: ghost-say --file <output.mp3> <text>", file=sys.stderr)
            sys.exit(1)
        output = sys.argv[2]
        text = " ".join(sys.argv[3:])
        voice.say_to_file(text, output)
        print(f"Saved: {output}")
        return
    else:
        text = " ".join(sys.argv[1:])

    if not text:
        print("No text provided.", file=sys.stderr)
        sys.exit(1)

    voice.say(text)


if __name__ == "__main__":
    main()
